---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import PrevNext from '../../components/docs/PrevNext.astro';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---

<DocsLayout title={entry.data.title} description={entry.data.description} headings={headings}>
  <h1 class="text-3xl font-bold tracking-tight">{entry.data.title}</h1>
  {entry.data.description && (
    <p class="mt-2 text-text-muted">{entry.data.description}</p>
  )}
  <div class="prose-invert mt-8">
    <Content />
  </div>
  <PrevNext currentId={entry.id} />
</DocsLayout>

<style is:global>
  .prose-invert {
    h2 {
      margin-top: 2rem;
      margin-bottom: 0.75rem;
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--color-text);
      border-bottom: 1px solid var(--color-border);
      padding-bottom: 0.5rem;
    }
    h3 {
      margin-top: 1.5rem;
      margin-bottom: 0.5rem;
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--color-text);
    }
    p {
      margin: 0.75rem 0;
      line-height: 1.75;
      color: var(--color-text-muted);
    }
    ul, ol {
      margin: 0.75rem 0;
      padding-left: 1.5rem;
      color: var(--color-text-muted);
    }
    li {
      margin: 0.25rem 0;
      line-height: 1.75;
    }
    strong {
      color: var(--color-text);
      font-weight: 600;
    }
    a {
      color: var(--color-accent);
      text-decoration: none;
    }
    a:hover {
      text-decoration: underline;
    }
    code {
      background: var(--color-brand-lighter);
      padding: 0.15rem 0.4rem;
      border-radius: 0.25rem;
      font-size: 0.875rem;
    }
    pre {
      background: var(--color-brand-light);
      border: 1px solid var(--color-border);
      border-radius: 0.5rem;
      padding: 1rem;
      overflow-x: auto;
      margin: 1rem 0;
    }
    pre code {
      background: none;
      padding: 0;
    }
    blockquote {
      border-left: 3px solid var(--color-accent);
      padding-left: 1rem;
      margin: 1rem 0;
      color: var(--color-text-muted);
      font-style: italic;
    }
    img {
      border-radius: 0.5rem;
      margin: 1rem 0;
      max-width: 100%;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin: 1rem 0;
    }
    th, td {
      border: 1px solid var(--color-border);
      padding: 0.5rem 0.75rem;
      text-align: left;
      font-size: 0.875rem;
    }
    th {
      background: var(--color-brand-lighter);
      color: var(--color-text);
      font-weight: 600;
    }
    td {
      color: var(--color-text-muted);
    }
    .doc-image-placeholder {
      margin: 1.5rem 0;
      border-radius: 0.5rem;
      overflow: hidden;
      border: 1px dashed var(--color-border);
      background: var(--color-brand-light);
      min-height: 200px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .doc-image-placeholder img {
      width: 100%;
      display: block;
      margin: 0;
      border-radius: 0;
    }
  }
</style>
