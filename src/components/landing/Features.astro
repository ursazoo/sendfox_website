---
import Container from '../shared/Container.astro';

const features = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
    title: '多平台账号管理',
    desc: '支持狐友、赞噢、逛逛等平台，通过桌面客户端抓包或手机验证码快速绑定账号',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>`,
    title: '智能内容采集',
    desc: '自动采集目标社区优质帖子，图片上传 OSS，内容去重，按学校定向采集',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 0 1 10 10 10 10 0 0 1-10 10A10 10 0 0 1 2 12 10 10 0 0 1 12 2z"/><path d="M12 16v-4M12 8h.01"/></svg>`,
    title: 'AI 审核与改写',
    desc: '敏感词过滤 + AI 内容审核，自动改写规避重复，确保每篇内容合规且独特',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/></svg>`,
    title: '自动发布分发',
    desc: '马甲号自动轮换，定时发布，多学校并发分发，失败自动重试',
  },
];
---

<section class="bg-muted/40 py-12 md:py-16">
  <Container>
    <div class="text-center">
      <h2 class="text-2xl font-bold tracking-tight md:text-3xl">核心能力</h2>
      <p class="mt-2 text-muted-foreground">覆盖社区运营全链路，从采集到发布一站式解决</p>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2">
      {features.map((f) => (
        <div class="flex gap-4 rounded-lg border border-border bg-card p-6 shadow-sm transition-all hover:shadow-md">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
            <Fragment set:html={f.icon} />
          </div>
          <div>
            <h3 class="font-semibold">{f.title}</h3>
            <p class="mt-1 text-sm leading-relaxed text-muted-foreground">{f.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </Container>
</section>
