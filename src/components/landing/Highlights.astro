---
import Container from '../shared/Container.astro';

const highlights = [
  {
    title: '桌面客户端抓包',
    desc: 'Electron 桌面工具自动拦截 HTTPS 请求，提取平台 Token，一键上传到管理后台',
    tag: '账号获取',
  },
  {
    title: '马甲号自动轮换',
    desc: '狐友平台发布时自动切换马甲号身份，支持从平台同步马甲号列表，降低营销号风险',
    tag: '安全分发',
  },
  {
    title: '学校包与名额管理',
    desc: '订阅套餐赠送学校名额，支持购买额外学校包，灵活分配采集源和发布目标',
    tag: '灵活计费',
  },
  {
    title: '微信支付订阅',
    desc: '支持微信支付在线订阅，开通对应套餐的学校名额',
    tag: '便捷支付',
  },
];
---

<section class="py-12 md:py-16">
  <Container>
    <div class="text-center">
      <h2 class="text-2xl font-bold tracking-tight md:text-3xl">产品亮点</h2>
      <p class="mt-2 text-muted-foreground">为高校社区运营场景深度定制</p>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-2">
      {highlights.map((h) => (
        <div class="rounded-lg border border-border bg-card p-6 shadow-sm transition-all hover:shadow-md">
          <div class="mb-3 inline-flex rounded-md bg-primary/10 px-2.5 py-1 text-xs font-medium text-primary">
            {h.tag}
          </div>
          <h3 class="font-semibold">{h.title}</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">{h.desc}</p>
        </div>
      ))}
    </div>
  </Container>
</section>
