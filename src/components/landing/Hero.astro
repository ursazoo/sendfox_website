---
import Container from '../shared/Container.astro';
---

<section class="relative overflow-hidden py-16 md:py-24">
  {/* 背景光晕 - 向上延伸到导航栏后面 */}
  <div class="pointer-events-none absolute left-1/2 top-[-80px] h-[600px] w-[600px] -translate-x-1/2 rounded-full" style="background:radial-gradient(circle, rgba(255,115,8,0.13) 0%, transparent 70%);"></div>
  <div class="pointer-events-none absolute right-[-5%] top-[10%] h-[350px] w-[350px] rounded-full" style="background:radial-gradient(circle, rgba(255,160,60,0.09) 0%, transparent 70%);"></div>
  <div class="pointer-events-none absolute left-[-5%] bottom-[10%] h-[250px] w-[250px] rounded-full" style="background:radial-gradient(circle, rgba(255,200,80,0.06) 0%, transparent 70%);"></div>

  <Container class="relative">
    <div class="mx-auto max-w-3xl text-center">
      <div class="glass-badge mb-6 inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-sm text-accent">
        <span class="h-1.5 w-1.5 rounded-full bg-accent animate-pulse"></span>
        面向高校社区的专业运营工具
      </div>

      <h1 class="text-4xl font-bold leading-tight tracking-tight md:text-5xl lg:text-6xl">
        让高校社区
        <span class="bg-gradient-to-r from-accent to-accent-light bg-clip-text text-transparent">运营更轻松</span>
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-text-muted md:text-xl">
        SendFox 帮助你轻松管理高校社区，自动采集和发布优质内容，智能审核过滤违规信息，让你的社区活跃起来。
      </p>

      <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="/docs/"
          class="inline-flex items-center gap-2 rounded-xl bg-accent px-8 py-3 text-base font-semibold text-white no-underline transition-all hover:bg-accent-light hover:shadow-lg hover:shadow-accent/25"
        >
          查看文档
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </Container>
</section>
