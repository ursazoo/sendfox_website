---
---

<div class="relative">
  <button
    id="search-toggle"
    class="flex w-full items-center gap-2 rounded-md border border-border bg-brand-light px-3 py-1.5 text-sm text-text-muted transition-colors hover:border-text-muted hover:text-text"
    aria-label="搜索文档"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
    </svg>
    <span>搜索文档...</span>
    <kbd class="ml-auto hidden rounded border border-border bg-brand px-1.5 py-0.5 text-xs md:inline">Ctrl K</kbd>
  </button>
</div>

{/* 搜索弹窗 */}
<div id="search-modal" class="fixed inset-0 z-50 hidden">
  <div class="fixed inset-0 bg-black/60 backdrop-blur-sm" id="search-backdrop"></div>
  <div class="fixed inset-x-4 top-[10%] mx-auto max-w-lg md:inset-x-auto md:left-1/2 md:-translate-x-1/2">
    <div class="overflow-hidden rounded-xl border border-border bg-brand-light shadow-2xl">
      <div class="flex items-center border-b border-border px-4">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-text-muted">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
        </svg>
        <input
          id="search-input"
          type="text"
          placeholder="搜索文档..."
          class="w-full border-0 bg-transparent px-3 py-3 text-sm text-text outline-none placeholder:text-text-muted"
          autocomplete="off"
        />
        <button id="search-close" class="text-xs text-text-muted hover:text-text">ESC</button>
      </div>
      <div id="search-results" class="max-h-80 overflow-y-auto p-2"></div>
    </div>
  </div>
</div>

<script>
  const toggle = document.getElementById('search-toggle');
  const modal = document.getElementById('search-modal');
  const backdrop = document.getElementById('search-backdrop');
  const input = document.getElementById('search-input') as HTMLInputElement;
  const results = document.getElementById('search-results');
  const close = document.getElementById('search-close');
  let pagefind: any = null;

  async function initPagefind() {
    if (!pagefind) {
      pagefind = await import('/pagefind/pagefind.js');
      await pagefind.options({ language: 'zh' });
    }
    return pagefind;
  }

  function openModal() {
    modal?.classList.remove('hidden');
    input?.focus();
  }

  function closeModal() {
    modal?.classList.add('hidden');
    input.value = '';
    if (results) results.innerHTML = '';
  }

  toggle?.addEventListener('click', openModal);
  backdrop?.addEventListener('click', closeModal);
  close?.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      if (modal?.classList.contains('hidden')) {
        openModal();
      } else {
        closeModal();
      }
    }
    if (e.key === 'Escape') closeModal();
  });

  let debounceTimer: ReturnType<typeof setTimeout>;
  input?.addEventListener('input', async () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(async () => {
      const query = input.value.trim();
      if (!query) {
        if (results) results.innerHTML = '';
        return;
      }
      const pf = await initPagefind();
      const search = await pf.search(query);
      if (results) {
        if (search.results.length === 0) {
          results.innerHTML = '<div class="px-3 py-6 text-center text-sm text-text-muted">没有找到相关内容</div>';
          return;
        }
        results.innerHTML = '';
        for (const result of search.results.slice(0, 8)) {
          const data = await result.data();
          const item = document.createElement('a');
          item.href = data.url;
          item.className = 'block rounded-lg px-3 py-2 no-underline transition-colors hover:bg-brand-lighter';
          item.innerHTML = `
            <div class="text-sm font-medium text-text">${data.meta?.title || ''}</div>
            <div class="mt-0.5 text-xs text-text-muted line-clamp-2">${data.excerpt || ''}</div>
          `;
          item.addEventListener('click', closeModal);
          results.appendChild(item);
        }
      }
    }, 200);
  });
</script>
