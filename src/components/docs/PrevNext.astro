---
import { getCollection } from 'astro:content';

interface Props {
  currentId: string;
}

const { currentId } = Astro.props;

const allDocs = (await getCollection('docs')).sort((a, b) => a.data.order - b.data.order);
const currentIndex = allDocs.findIndex((d) => d.id === currentId);
const prev = currentIndex > 0 ? allDocs[currentIndex - 1] : null;
const next = currentIndex < allDocs.length - 1 ? allDocs[currentIndex + 1] : null;
---

{(prev || next) && (
  <div class="mt-12 flex items-center justify-between border-t border-border pt-6">
    {prev ? (
      <a
        href={`/docs/${prev.id}/`}
        class="group flex flex-col no-underline"
      >
        <span class="text-xs text-muted-foreground">上一篇</span>
        <span class="text-sm text-foreground transition-colors group-hover:text-foreground/80">
          &larr; {prev.data.title}
        </span>
      </a>
    ) : <div />}

    {next ? (
      <a
        href={`/docs/${next.id}/`}
        class="group flex flex-col items-end no-underline"
      >
        <span class="text-xs text-muted-foreground">下一篇</span>
        <span class="text-sm text-foreground transition-colors group-hover:text-foreground/80">
          {next.data.title} &rarr;
        </span>
      </a>
    ) : <div />}
  </div>
)}
