---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border bg-card">
  <div class="mx-auto max-w-6xl px-4 py-12 md:px-6">
    <div class="grid gap-8 md:grid-cols-3">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
          <span class="font-bold">SendFox</span>
        </div>
        <p class="mt-3 text-sm text-muted-foreground">
          面向高校社区的专业运营工具
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-sm font-semibold">导航</h3>
        <ul class="mt-3 space-y-2">
          <li><a href="/" class="text-sm text-muted-foreground no-underline hover:text-foreground">首页</a></li>
          <li><a href="/docs/" class="text-sm text-muted-foreground no-underline hover:text-foreground">使用文档</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-semibold">联系我们</h3>
        <ul class="mt-3 space-y-2">
          <li class="text-sm text-muted-foreground">如有问题或合作需求，请联系 <a href="mailto:iamzhoufei@gmail.com" class="text-primary hover:underline">iamzhoufei@gmail.com</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-8 border-t border-border pt-6 text-center text-xs text-muted-foreground">
      &copy; {currentYear} SendFox. All rights reserved.
    </div>
  </div>
</footer>
