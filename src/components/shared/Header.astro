---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: '首页' },
  { href: '/docs/', label: '文档' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-border bg-brand/80 backdrop-blur-md">
  <div class="mx-auto flex h-14 max-w-6xl items-center justify-between px-4 md:px-6">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 text-text no-underline">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-accent">
        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="text-lg font-bold tracking-tight">SendFox</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden items-center gap-6 md:flex">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'text-sm transition-colors no-underline',
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'text-accent'
              : 'text-text-muted hover:text-text',
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href="/admin/"
        target="_blank"
        class="rounded-md bg-accent px-3 py-1.5 text-sm font-medium text-white no-underline transition-colors hover:bg-accent-light"
      >
        进入后台
      </a>
    </nav>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="flex items-center justify-center rounded-md p-2 text-text-muted transition-colors hover:text-text md:hidden"
      aria-label="打开菜单"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden border-t border-border md:hidden">
    <nav class="flex flex-col gap-1 px-4 py-3">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'rounded-md px-3 py-2 text-sm no-underline',
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'bg-brand-lighter text-accent'
              : 'text-text-muted hover:bg-brand-lighter hover:text-text',
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href="/admin/"
        target="_blank"
        class="mt-2 rounded-md bg-accent px-3 py-2 text-center text-sm font-medium text-white no-underline"
      >
        进入后台
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
